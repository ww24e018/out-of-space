  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@types/d3": "^7.4.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "d3": "^7.9.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "pinia": "^3.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.5"
  }
}
